# Public site URL — used for canonicals, sitemap, OG images
NEXT_PUBLIC_SITE_URL=https://baliairconditioning.com

# Google Analytics 4 measurement ID (G-XXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (the value after "google-site-verification=")
NEXT_PUBLIC_GSC_VERIFICATION=

# Quote form: where to forward submissions
QUOTE_RECIPIENT_EMAIL=
QUOTE_RECIPIENT_WHATSAPP=6281808029595

# Optional: Telegram bot for quote notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: SMTP (or use a transactional provider like Resend / SendGrid)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
